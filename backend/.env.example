# --- Runtime ---
NODE_ENV=development
PORT=5000
HOST=127.0.0.1
API_PREFIX=/api/v1

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clinical_narrative_platform

# --- Auth / sessions ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- AI / Gemini (general platform features: narratives, insights, doctor summaries) ---
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_API_MODEL=gemini-2.5-flash

# --- AI Copilot (RAG chat + embeddings) ---
# Optional separate key so copilot quota can be tracked independently.
# If unset, the copilot falls back to GEMINI_API_KEY.
GEMINI_COPILOT_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Must match the dimension of the Pinecone index you created.
GEMINI_EMBEDDING_DIMENSIONS=768

# --- Pinecone vector store (per-user namespaces for copilot RAG) ---
# Leave both blank to disable doc upload + RAG retrieval; chat will still
# work using platform-only context (logged symptoms, AI summaries).
# Index must use the same dimension as GEMINI_EMBEDDING_DIMENSIONS and cosine metric.
PINECONE_API_KEY=
PINECONE_INDEX=

# --- Copilot ingestion / retrieval tuning ---
COPILOT_MAX_UPLOAD_BYTES=10485760
COPILOT_CHUNK_SIZE=1200
COPILOT_CHUNK_OVERLAP=180
COPILOT_TOP_K=6
COPILOT_EMBEDDING_BATCH=16

# --- PDF rendering ---
# puppeteer downloads its own Chromium during `npm install`. Leave unset to
# use that bundled binary. Set this only to override (e.g. point at a system
# Chrome to skip the download).
# CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome

# --- Misc ---
UPLOAD_DIR=uploads
LOG_LEVEL=info
