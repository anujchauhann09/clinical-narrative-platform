generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  PATIENT @map("patient")
  ADMIN   @map("admin")

  @@map("role_name")
}

model User {
  id                  BigInt    @id @default(autoincrement())
  publicId            String    @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  email               String    @unique @db.VarChar(320)
  // Nullable: accounts created via OAuth (e.g. Google) have no local password.
  passwordHash        String?   @map("password_hash") @db.Text
  roleName            RoleName  @default(PATIENT) @map("role_name")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until") @db.Timestamptz(6)
  lastLoginAt         DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  profile          UserProfile?
  symptomEntries   SymptomEntry[]
  aiSummaries      AiSummary[]
  refreshTokens    RefreshToken[]
  copilotDocuments CopilotDocument[]
  patternInsights  PatternInsight[]
  oauthAccounts    OAuthAccount[]
  role             Role              @relation(fields: [roleName], references: [name], onDelete: Restrict)

  @@index([roleName], map: "idx_users_role_name")
  @@index([createdAt], map: "idx_users_created_at")
  @@map("users")
}

model OAuthAccount {
  id             BigInt   @id @default(autoincrement())
  publicId       String   @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  userId         BigInt   @map("user_id")
  provider       String   @db.VarChar(40)
  providerUserId String   @map("provider_user_id") @db.VarChar(255)
  email          String?  @db.VarChar(320)
  avatarUrl      String?  @map("avatar_url") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId], map: "uq_oauth_accounts_provider_user")
  @@index([userId], map: "idx_oauth_accounts_user_id")
  @@map("oauth_accounts")
}

model Role {
  id          BigInt   @id @default(autoincrement())
  publicId    String   @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  name        RoleName @unique
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users User[]

  @@index([createdAt], map: "idx_roles_created_at")
  @@map("roles")
}

model RefreshToken {
  id        BigInt    @id @default(autoincrement())
  publicId  String    @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  userId    BigInt    @map("user_id")
  tokenHash String    @unique @map("token_hash") @db.Text
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt], map: "idx_refresh_tokens_user_revoked_at")
  @@index([expiresAt], map: "idx_refresh_tokens_expires_at")
  @@index([createdAt], map: "idx_refresh_tokens_created_at")
  @@map("refresh_tokens")
}

model UserProfile {
  id          BigInt   @id @default(autoincrement())
  publicId    String   @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  userId      BigInt   @unique @map("user_id")
  name        String   @db.VarChar(160)
  bio         String?  @db.Text
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  sex         String?  @db.VarChar(40)
  phone       String?  @db.VarChar(32)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt], map: "idx_user_profiles_created_at")
  @@map("user_profiles")
}

model SymptomEntry {
  id        BigInt   @id @default(autoincrement())
  publicId  String   @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  userId    BigInt   @map("user_id")
  severity  Int      @db.SmallInt
  mood      String?  @db.VarChar(80)
  notes     String?  @db.Text
  loggedAt  DateTime @map("logged_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  symptoms EntrySymptom[]
  triggers EntryTrigger[]

  @@index([userId, loggedAt(sort: Desc)], map: "idx_symptom_entries_user_logged_at")
  @@index([createdAt], map: "idx_symptom_entries_created_at")
  @@map("symptom_entries")
}

model Symptom {
  id        BigInt   @id @default(autoincrement())
  publicId  String   @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  name      String   @db.VarChar(120)
  category  String   @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  entries EntrySymptom[]

  @@unique([name, category], map: "uq_symptoms_name_category")
  @@index([category], map: "idx_symptoms_category")
  @@index([createdAt], map: "idx_symptoms_created_at")
  @@map("symptoms")
}

model EntrySymptom {
  entryId   BigInt   @map("entry_id")
  symptomId BigInt   @map("symptom_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  entry   SymptomEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  symptom Symptom      @relation(fields: [symptomId], references: [id], onDelete: Restrict)

  @@id([entryId, symptomId])
  @@index([symptomId], map: "idx_entry_symptoms_symptom_id")
  @@index([createdAt], map: "idx_entry_symptoms_created_at")
  @@map("entry_symptoms")
}

model Trigger {
  id        BigInt   @id @default(autoincrement())
  publicId  String   @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  name      String   @unique @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  entries EntryTrigger[]

  @@index([createdAt], map: "idx_triggers_created_at")
  @@map("triggers")
}

model EntryTrigger {
  entryId   BigInt   @map("entry_id")
  triggerId BigInt   @map("trigger_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  entry   SymptomEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  trigger Trigger      @relation(fields: [triggerId], references: [id], onDelete: Restrict)

  @@id([entryId, triggerId])
  @@index([triggerId], map: "idx_entry_triggers_trigger_id")
  @@index([createdAt], map: "idx_entry_triggers_created_at")
  @@map("entry_triggers")
}

model AiSummary {
  id          BigInt   @id @default(autoincrement())
  publicId    String   @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  userId      BigInt   @map("user_id")
  summaryType String   @map("summary_type") @db.VarChar(80)
  content     String   @db.Text
  generatedAt DateTime @default(now()) @map("generated_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, generatedAt(sort: Desc)], map: "idx_ai_summaries_user_generated_at")
  @@index([summaryType], map: "idx_ai_summaries_summary_type")
  @@index([createdAt], map: "idx_ai_summaries_created_at")
  @@map("ai_summaries")
}

model CopilotDocument {
  id           BigInt    @id @default(autoincrement())
  publicId     String    @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  userId       BigInt    @map("user_id")
  filename     String    @db.VarChar(255)
  mimeType     String    @map("mime_type") @db.VarChar(120)
  byteSize     Int       @map("byte_size")
  chunkCount   Int       @default(0) @map("chunk_count")
  status       String    @default("processing") @db.VarChar(40)
  errorMessage String?   @map("error_message") @db.Text
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], map: "idx_copilot_documents_user_created_at")
  @@index([status], map: "idx_copilot_documents_status")
  @@index([deletedAt], map: "idx_copilot_documents_deleted_at")
  @@map("copilot_documents")
}

model PatternInsight {
  id               BigInt    @id @default(autoincrement())
  publicId         String    @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  userId           BigInt    @map("user_id")
  patternKey       String    @map("pattern_key") @db.VarChar(80)
  title            String    @db.VarChar(160)
  observation      String    @db.Text
  discussionTopics Json      @map("discussion_topics")
  severity         String    @default("informational") @db.VarChar(40)
  confidence       String    @default("low") @db.VarChar(40)
  evidenceCount    Int       @default(0) @map("evidence_count")
  windowStart      DateTime  @map("window_start") @db.Timestamptz(6)
  windowEnd        DateTime  @map("window_end") @db.Timestamptz(6)
  dismissedAt      DateTime? @map("dismissed_at") @db.Timestamptz(6)
  feedback         String?   @db.VarChar(40)
  expiresAt        DateTime? @map("expires_at") @db.Timestamptz(6)
  generatedAt      DateTime  @default(now()) @map("generated_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, patternKey, windowStart], map: "uq_pattern_insights_user_key_window")
  @@index([userId, generatedAt(sort: Desc)], map: "idx_pattern_insights_user_generated_at")
  @@index([dismissedAt], map: "idx_pattern_insights_dismissed_at")
  @@map("pattern_insights")
}

model AuditLog {
  id            BigInt   @id @default(autoincrement())
  publicId      String   @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  userPublicId  String?  @map("user_public_id") @db.Uuid
  action        String   @db.VarChar(80)
  resourceType  String?  @map("resource_type") @db.VarChar(80)
  resourceId    String?  @map("resource_id") @db.VarChar(128)
  ip            String?  @db.VarChar(64)
  userAgent     String?  @map("user_agent") @db.VarChar(512)
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userPublicId, createdAt(sort: Desc)], map: "idx_audit_logs_user_created_at")
  @@index([action, createdAt(sort: Desc)], map: "idx_audit_logs_action_created_at")
  @@index([resourceType, resourceId], map: "idx_audit_logs_resource")
  @@map("audit_logs")
}
